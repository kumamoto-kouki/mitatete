{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mitatete",
  "version": "0.1.0",
  "identifier": "com.mitatete.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Mitatete",
        "url": "index.html",
        "width": 420,
        "height": 640,
        "resizable": true
      },
      {
        "label": "character",
        "url": "character.html",
        "width": 120,
        "height": 200,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
